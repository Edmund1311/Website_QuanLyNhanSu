@page
@model Website_Quản_Lý_Nhân_Sự.Pages.AdminManagement.CreateModel
@{ ViewData["Title"] = "Tạo quản trị viên mới"; }

<div class="page-header">
    <h1 class="h3">Tạo quản trị viên mới</h1>
</div>

<div class="card form-card">
    <div class="card-body p-4">
        <form method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <strong>Vui lòng kiểm tra các lỗi dưới đây:</strong>
                    <ul class="mb-0 mt-2">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Email <span class="text-danger">*</span></label>
                <input asp-for="Input.Email" class="form-control" type="email" required />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                <input asp-for="Input.Password" class="form-control" type="password" required />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" type="password" required />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Công ty <span class="text-danger">*</span></label>
                <select asp-for="Input.CompanyId" class="form-select" required>
                    <option value="">-- Chọn công ty --</option>
                    @foreach (var company in Model.Companies)
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.CompanyId" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn btn-primary">Tạo</button>
                <a asp-page="Index" class="btn btn-link">Hủy</a>
            </div>
        </form>
    </div>
</div>
