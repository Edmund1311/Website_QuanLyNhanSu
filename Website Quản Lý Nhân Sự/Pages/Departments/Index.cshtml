@page
@model Website_Quản_Lý_Nhân_Sự.Pages.Departments.IndexModel
@{ ViewData["Title"] = "Phòng ban"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <div><h1 class="h3 mb-1">Phòng ban</h1></div>
    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm</a>
</div>
<div class="card table-card mb-3"><div class="card-body">
<form method="get" class="row g-2"><div class="col-md-6"><input asp-for="Search" class="form-control" placeholder="Tìm kiếm..." /></div><div class="col-md-2"><button class="btn btn-outline-primary">Tìm</button></div></form>
</div></div>
<div class="card table-card"><div class="table-responsive"><table class="table mb-0">
<thead><tr><th>Tên</th><th>Mô tả</th><th></th></tr></thead>
<tbody>@foreach (var item in Model.Departments){<tr><td>@item.Name</td><td>@item.Description</td><td class="text-end">
<a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
<form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa phòng ban?')">Xóa</button></form>
</td></tr>}</tbody></table></div></div>
