@page
@model Website_Quản_Lý_Nhân_Sự.Pages.LeaveRequests.CreateModel
@{ ViewData["Title"] = "Tạo đơn nghỉ phép"; }
<div class="card form-card"><div class="card-body p-4"><form method="post">
<div class="mb-3"><label class="form-label">Từ ngày</label><input asp-for="LeaveRequest.StartDate" class="form-control" type="date" /></div>
<div class="mb-3"><label class="form-label">Đến ngày</label><input asp-for="LeaveRequest.EndDate" class="form-control" type="date" /></div>
<div class="mb-3"><label class="form-label">Loại nghỉ</label><input asp-for="LeaveRequest.LeaveType" class="form-control" /></div>
<div class="mb-3"><label class="form-label">Lý do</label><textarea asp-for="LeaveRequest.Reason" class="form-control"></textarea></div>
<button class="btn btn-primary">Gửi đơn</button></form></div></div>
