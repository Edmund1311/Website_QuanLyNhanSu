@page
@model Website_Quản_Lý_Nhân_Sự.Pages.LeaveRequests.IndexModel
@{ ViewData["Title"] = "Nghỉ phép"; }
<div class="page-header d-flex justify-content-between"><h1 class="h3">Nghỉ phép</h1>@if(User.IsInRole(RoleNames.Employee)){<a asp-page="Create" class="btn btn-primary">Tạo đơn</a>}</div>
<div class="card table-card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Nhân viên</th><th>Từ ngày</th><th>Đến ngày</th><th>Loại</th><th>Trạng thái</th><th></th></tr></thead><tbody>
@foreach(var item in Model.Requests){
<tr><td>@item.Employee?.FullName</td><td>@item.StartDate.ToString("dd/MM/yyyy")</td><td>@item.EndDate.ToString("dd/MM/yyyy")</td><td>@item.LeaveType</td><td>@DisplayHelper.LeaveStatus(item.Status)</td><td>
@if(Model.CanManageHR && item.Status == LeaveRequestStatus.Pending){
<form method="post" asp-page-handler="Approve" asp-route-id="@item.Id" class="d-inline"><button class="btn btn-sm btn-success">Duyệt</button></form>
<form method="post" asp-page-handler="Reject" asp-route-id="@item.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger">Từ chối</button></form>}
</td></tr>}
</tbody></table></div></div>
