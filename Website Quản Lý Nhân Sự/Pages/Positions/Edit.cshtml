@page "{id:int}"
@model Website_Quản_Lý_Nhân_Sự.Pages.Positions.EditModel
@{ ViewData["Title"] = "Sửa chức vụ"; }
<div class="page-header"><h1 class="h3">Sửa chức vụ</h1></div>
<div class="card form-card"><div class="card-body p-4"><form method="post">
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Vui lòng kiểm tra các lỗi dưới đây:</strong>
        <ul class="mb-0 mt-2">
            @foreach (var modelState in ViewData.ModelState.Values)
            {
                @foreach (var error in modelState.Errors)
                {
                    <li>@error.ErrorMessage</li>
                }
            }
        </ul>
    </div>
}
<input type="hidden" asp-for="Position.Id" />
<div class="mb-3"><label class="form-label">Tên chức vụ <span class="text-danger">*</span></label><input asp-for="Position.Name" class="form-control" required /></div>
<div class="mb-3"><label class="form-label">Lương cơ bản <span class="text-danger">*</span></label><input asp-for="Position.BaseSalary" class="form-control" type="number" required /></div>
<div class="mb-3"><label class="form-label">Mô tả</label><textarea asp-for="Position.Description" class="form-control"></textarea></div>
<button class="btn btn-primary">Cập nhật</button> <a asp-page="Index" class="btn btn-link">Hủy</a></form></div></div>
