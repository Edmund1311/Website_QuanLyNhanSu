@page "{id:int}"
@model Website_Quản_Lý_Nhân_Sự.Pages.Contracts.EditModel
@{ ViewData["Title"] = "Sửa hợp đồng"; }
<div class="page-header"><h1 class="h3">Sửa hợp đồng</h1></div>
<div class="card form-card"><div class="card-body p-4"><form method="post">
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Vui lòng kiểm tra các lỗi dưới đây:</strong>
        <ul class="mb-0 mt-2">
            @foreach (var modelState in ViewData.ModelState.Values)
            {
                @foreach (var error in modelState.Errors)
                {
                    <li>@error.ErrorMessage</li>
                }
            }
        </ul>
    </div>
}
<input type="hidden" asp-for="Contract.Id" /><input type="hidden" asp-for="Contract.EmployeeId" />
<div class="mb-3"><label class="form-label">Mã hợp đồng <span class="text-danger">*</span></label><input asp-for="Contract.ContractCode" class="form-control" required /></div>
<div class="mb-3"><label class="form-label">Ngày bắt đầu <span class="text-danger">*</span></label><input asp-for="Contract.StartDate" class="form-control" type="date" required /></div>
<div class="mb-3"><label class="form-label">Ngày kết thúc <span class="text-danger">*</span></label><input asp-for="Contract.EndDate" class="form-control" type="date" required /></div>
<div class="mb-3"><label class="form-label">Mức lương <span class="text-danger">*</span></label><input asp-for="Contract.Salary" class="form-control" type="number" required /></div>
<button class="btn btn-primary">Cập nhật</button> <a asp-page-handler="ExportPdf" asp-route-id="@Model.Contract.Id" class="btn btn-outline-danger">Xuất PDF</a> <a asp-page="Index" class="btn btn-link">Hủy</a>
</form></div></div>
