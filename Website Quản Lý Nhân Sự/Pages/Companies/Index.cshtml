@page
@model Website_Quản_Lý_Nhân_Sự.Pages.Companies.IndexModel
@{
    ViewData["Title"] = "Quản lý công ty";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div><h1 class="h3 mb-1">Công ty</h1><p class="text-muted mb-0">Quản lý doanh nghiệp trên nền tảng SaaS</p></div>
    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Thêm công ty</a>
</div>

<div class="card table-card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-6"><input asp-for="Search" class="form-control" placeholder="Tìm theo tên, mã, email..." /></div>
            <div class="col-md-2"><button class="btn btn-outline-primary w-100">Tìm kiếm</button></div>
        </form>
    </div>
</div>

<div class="card table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead><tr><th>Mã</th><th>Tên công ty</th><th>Email</th><th>Trạng thái</th><th>Ngày tạo</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model.Companies)
            {
                <tr>
                    <td><span class="badge bg-secondary">@item.Code</span></td>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@DisplayHelper.GetCompanyStatusText(item.Status)</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <form method="post" asp-page-handler="ToggleLock" asp-route-id="@item.Id" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-warning">@(item.Status == CompanyStatus.Active ? "Khóa" : "Mở khóa")</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
