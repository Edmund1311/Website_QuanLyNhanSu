<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRMS SaaS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true && ViewData["UseAuthLayout"] as bool? != true)
{
    var isSuperAdmin = User.IsInRole(RoleNames.SuperAdmin);
    var isCompanyAdmin = User.IsInRole(RoleNames.CompanyAdmin);
    var isHR = User.IsInRole(RoleNames.HR);
    var isEmployeeOnly = User.IsInRole(RoleNames.Employee) && !isCompanyAdmin && !isHR && !isSuperAdmin;
    var canManageHR = isCompanyAdmin || isHR;

    <div class="d-flex flex-column flex-lg-row">
        <aside class="sidebar p-3">
            <div class="brand mb-4">
                <i class="bi bi-people-fill me-2"></i>HRMS SaaS
            </div>
            <nav class="nav flex-column">
                @if (isSuperAdmin)
                {
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Companies") == true ? "active" : "")" asp-page="/Companies/Index">
                        <i class="bi bi-building me-2"></i>Công ty
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/AdminManagement") == true ? "active" : "")" asp-page="/AdminManagement/Index">
                        <i class="bi bi-shield-check me-2"></i>Quản lý quản trị viên
                    </a>
                }
                else if (canManageHR)
                {
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Dashboard") == true ? "active" : "")" asp-page="/Dashboard/Index">
                        <i class="bi bi-speedometer2 me-2"></i>Bảng điều khiển
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Departments") == true ? "active" : "")" asp-page="/Departments/Index">
                        <i class="bi bi-diagram-3 me-2"></i>Phòng ban
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Positions") == true ? "active" : "")" asp-page="/Positions/Index">
                        <i class="bi bi-briefcase me-2"></i>Chức vụ
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Employees") == true ? "active" : "")" asp-page="/Employees/Index">
                        <i class="bi bi-person-badge me-2"></i>Nhân viên
                    </a>
                    @if (isCompanyAdmin)
                    {
                        <a class="nav-link @(Context.Request.Path.Value?.Contains("/JoinRequests/Index") == true ? "active" : "")" asp-page="/JoinRequests/Index">
                            <i class="bi bi-person-check me-2"></i>Duyệt tham gia
                        </a>
                    }
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Attendance") == true ? "active" : "")" asp-page="/Attendance/Index">
                        <i class="bi bi-clock-history me-2"></i>Chấm công
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/LeaveRequests") == true ? "active" : "")" asp-page="/LeaveRequests/Index">
                        <i class="bi bi-calendar2-minus me-2"></i>Nghỉ phép
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Contracts") == true ? "active" : "")" asp-page="/Contracts/Index">
                        <i class="bi bi-file-earmark-text me-2"></i>Hợp đồng
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Salaries") == true ? "active" : "")" asp-page="/Salaries/Index">
                        <i class="bi bi-cash-stack me-2"></i>Bảng lương
                    </a>
                }
                else if (isEmployeeOnly)
                {
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Dashboard") == true ? "active" : "")" asp-page="/Dashboard/Index">
                        <i class="bi bi-house me-2"></i>Trang chủ
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/Employees/Profile") == true ? "active" : "")" asp-page="/Employees/Profile">
                        <i class="bi bi-person-circle me-2"></i>Thông tin cá nhân
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/LeaveRequests") == true ? "active" : "")" asp-page="/LeaveRequests/Index">
                        <i class="bi bi-calendar2-minus me-2"></i>Nghỉ phép
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/EmployeeMedia") == true ? "active" : "")" asp-page="/EmployeeMedia/Index">
                        <i class="bi bi-folder2-open me-2"></i>Hồ sơ điện tử
                    </a>
                    <a class="nav-link @(Context.Request.Path.Value?.Contains("/JoinRequests/My") == true ? "active" : "")" asp-page="/JoinRequests/My">
                        <i class="bi bi-door-open me-2"></i>Tham gia công ty
                    </a>
                }
                <a class="nav-link @(Context.Request.Path.Value?.Contains("/Account/ChangePassword") == true ? "active" : "")" asp-page="/Account/ChangePassword">
                    <i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu
                </a>
                <form method="post" asp-page="/Account/Logout" class="mt-3">
                    <button type="submit" class="btn btn-outline-light w-100">
                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                    </button>
                </form>
            </nav>
        </aside>
        <main class="main-content flex-grow-1 p-4">
            @if (TempData["Message"] is string message)
            {
                <div class="alert alert-success">@message</div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger">@error</div>
            }
            @RenderBody()
        </main>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
