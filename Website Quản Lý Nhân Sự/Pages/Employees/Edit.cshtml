@page "{id:int}"
@model Website_Quản_Lý_Nhân_Sự.Pages.Employees.EditModel
@{ ViewData["Title"] = "Sửa nhân viên"; }
<div class="card form-card"><div class="card-body p-4"><form method="post" enctype="multipart/form-data">
<input type="hidden" asp-for="Employee.Id" /><input type="hidden" asp-for="Employee.AvatarPath" />
<div class="row g-3">
<div class="col-md-4"><label class="form-label">Mã nhân viên</label><input asp-for="Employee.EmployeeCode" class="form-control" /></div>
<div class="col-md-4"><label class="form-label">Họ tên</label><input asp-for="Employee.FullName" class="form-control" /></div>
<div class="col-md-4"><label class="form-label">Email</label><input asp-for="Employee.Email" class="form-control" /></div>
<div class="col-md-4"><label class="form-label">Phòng ban</label><select asp-for="Employee.DepartmentId" class="form-select" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))"></select></div>
<div class="col-md-4"><label class="form-label">Chức vụ</label><select asp-for="Employee.PositionId" class="form-select" asp-items="@(new SelectList(Model.Positions, "Id", "Name"))"></select></div>
<div class="col-md-4"><label class="form-label">Trạng thái</label><select asp-for="Employee.WorkStatus" class="form-select" asp-items="Html.GetEnumSelectList<WorkStatus>()"></select></div>
<div class="col-md-6"><label class="form-label">Avatar mới</label><input asp-for="AvatarFile" class="form-control" type="file" /></div>
</div><div class="mt-4"><button class="btn btn-primary">Cập nhật</button></div></form></div></div>
