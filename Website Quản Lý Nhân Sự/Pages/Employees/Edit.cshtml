@page "{id:int}"
@model Website_Quản_Lý_Nhân_Sự.Pages.Employees.EditModel
@{ ViewData["Title"] = "Sửa nhân viên"; }
<div class="page-header"><h1 class="h3">Sửa nhân viên</h1></div>
<div class="card form-card"><div class="card-body p-4"><form method="post" enctype="multipart/form-data">
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Vui lòng kiểm tra các lỗi dưới đây:</strong>
        <ul class="mb-0 mt-2">
            @foreach (var modelState in ViewData.ModelState.Values)
            {
                @foreach (var error in modelState.Errors)
                {
                    <li>@error.ErrorMessage</li>
                }
            }
        </ul>
    </div>
}
<input type="hidden" asp-for="Employee.Id" /><input type="hidden" asp-for="Employee.AvatarPath" />
<div class="row g-3">
<div class="col-md-4"><label class="form-label">Mã nhân viên</label><input asp-for="Employee.EmployeeCode" class="form-control" readonly /></div>
<div class="col-md-4"><label class="form-label">Họ tên <span class="text-danger">*</span></label><input asp-for="Employee.FullName" class="form-control" required /></div>
<div class="col-md-4"><label class="form-label">Email <span class="text-danger">*</span></label><input asp-for="Employee.Email" class="form-control" type="email" required /></div>
<div class="col-md-4"><label class="form-label">Phòng ban <span class="text-danger">*</span></label><select asp-for="Employee.DepartmentId" class="form-select" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))" required></select></div>
<div class="col-md-4"><label class="form-label">Chức vụ <span class="text-danger">*</span></label><select asp-for="Employee.PositionId" class="form-select" asp-items="@(new SelectList(Model.Positions, "Id", "Name"))" required></select></div>
<div class="col-md-4"><label class="form-label">Trạng thái</label><select asp-for="Employee.WorkStatus" class="form-select" asp-items="Html.GetEnumSelectList<WorkStatus>()"></select></div>
<div class="col-md-6"><label class="form-label">Avatar mới</label><input asp-for="AvatarFile" class="form-control" type="file" /></div>
</div><div class="mt-4"><button class="btn btn-primary">Cập nhật</button> <a asp-page="Index" class="btn btn-link">Hủy</a></div></form></div></div>
