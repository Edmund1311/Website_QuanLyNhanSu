@page
@model Website_Quản_Lý_Nhân_Sự.Pages.Employees.ProfileModel
@{ ViewData["Title"] = "Thông tin cá nhân"; var e = Model.Employee!; }
<div class="page-header"><h1 class="h3">Thông tin cá nhân</h1></div>
<div class="row g-4">
    <div class="col-lg-4">
        <div class="card form-card text-center p-4">
            <img src="@AvatarHelper.GetUrl(e.AvatarPath)" alt="@e.FullName" class="employee-avatar-lg mx-auto mb-3" />
            <h2 class="h5">@e.FullName</h2>
            <p class="text-muted">@e.EmployeeCode</p>
            <form method="post" enctype="multipart/form-data" class="mt-3 text-start">
                <label class="form-label">Cập nhật ảnh đại diện</label>
                <input asp-for="AvatarFile" class="form-control mb-2" type="file" accept="image/*" />
                <button class="btn btn-primary w-100">Lưu ảnh</button>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card form-card">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6"><strong>Email:</strong> @e.Email</div>
                    <div class="col-md-6"><strong>Điện thoại:</strong> @(e.Phone ?? "—")</div>
                    <div class="col-md-6"><strong>Phòng ban:</strong> @e.Department?.Name</div>
                    <div class="col-md-6"><strong>Chức vụ:</strong> @e.Position?.Name</div>
                    <div class="col-md-6"><strong>Ngày sinh:</strong> @(e.DateOfBirth?.ToString("dd/MM/yyyy") ?? "—")</div>
                    <div class="col-md-6"><strong>Giới tính:</strong> @DisplayHelper.Gender(e.Gender)</div>
                    <div class="col-md-6"><strong>Ngày vào làm:</strong> @e.HireDate.ToString("dd/MM/yyyy")</div>
                    <div class="col-md-6"><strong>Trạng thái:</strong> @DisplayHelper.WorkStatus(e.WorkStatus)</div>
                    <div class="col-12"><strong>Địa chỉ:</strong> @(e.Address ?? "—")</div>
                </div>
                <div class="mt-4">
                    <a asp-page="/Dashboard/Index" class="btn btn-outline-secondary">Về trang chủ</a>
                    <a asp-page="Details" asp-route-id="@e.Id" class="btn btn-outline-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
    </div>
</div>
