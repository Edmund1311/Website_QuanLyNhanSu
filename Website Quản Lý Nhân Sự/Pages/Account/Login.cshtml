@page
@model Website_Quản_Lý_Nhân_Sự.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["UseAuthLayout"] = true;
    Layout = "_Layout";
}

<div class="auth-body d-flex align-items-center justify-content-center p-3">
    <div class="card auth-card w-100" style="max-width:420px">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h2 class="fw-bold">HRMS SaaS</h2>
                <p class="text-muted mb-0">Đăng nhập hệ thống quản lý nhân sự</p>
            </div>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="admin@hrms.local" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <input asp-for="Input.Password" class="form-control" />
                </div>
                <div class="form-check mb-3">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label class="form-check-label">Ghi nhớ đăng nhập</label>
                </div>
                <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
            </form>
            <div class="text-center mt-3">
                <a asp-page="/Account/Register">Tạo tài khoản mới</a> ·
                <a asp-page="/Index">Trang chủ</a>
            </div>
            <div class="small text-muted mt-3">
                Demo: admin@hrms.local / Admin@123
            </div>
        </div>
    </div>
</div>
