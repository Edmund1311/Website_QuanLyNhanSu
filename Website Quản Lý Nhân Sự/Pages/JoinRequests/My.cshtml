@page
@model Website_Quản_Lý_Nhân_Sự.Pages.JoinRequests.MyModel
@{ ViewData["Title"] = "Tham gia công ty"; }
<div class="page-header"><h1 class="h3">Tham gia công ty</h1></div>
<div class="card form-card mb-4"><div class="card-body p-4"><form method="post" class="row g-2">
<div class="col-md-4"><input asp-for="CompanyCode" class="form-control" placeholder="Nhập mã công ty (VD: DEMO01)" required /></div>
<div class="col-md-2"><button class="btn btn-primary">Gửi yêu cầu</button></div></form></div></div>
<div class="card table-card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Công ty</th><th>Ngày gửi</th><th>Trạng thái</th><th>Ghi chú</th></tr></thead><tbody>
@foreach(var item in Model.Requests){<tr><td>@item.Company.Name (@item.Company.Code)</td><td>@item.SubmittedAt.ToLocalTime()</td><td><span class="badge @DisplayHelper.BadgeClassForJoinStatus(item.Status)">@DisplayHelper.JoinStatus(item.Status)</span></td><td>@item.Note</td></tr>}
</tbody></table></div></div>
